# ============================================================
# Retail AI Store Assistant — Backend Environment Variables
# Copy this file to backend/.env and fill in your values.
# ============================================================

# ---- Neo4j AuraDB ----------------------------------------
# Create a free instance at https://neo4j.com/cloud/aura/
NEO4J_URI=neo4j+s://YOUR_INSTANCE.databases.neo4j.io
NEO4J_USERNAME=your_username
NEO4J_PASSWORD=your_password

# ---- LLMs ------------------------------------------------
# Groq (primary LLM — fast, free tier): https://console.groq.com
GROQ_API_KEY=gsk_...

# Google Gemini (fallback LLM): https://aistudio.google.com
GEMINI_API_KEY=AIza...

# ---- Embeddings ------------------------------------------
# OpenAI (embeddings + fallback LLM): https://platform.openai.com
OPENAI_API_KEY=sk-proj-...

# ---- Monitoring ------------------------------------------
# Langfuse (free cloud tier): https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Human-in-Loop ---------------------------------------
# Slack Incoming Webhook: https://api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ---- Text-to-Speech --------------------------------------
# Google Cloud TTS Neural2: https://console.cloud.google.com
GOOGLE_TTS_API_KEY=your_google_tts_api_key

# ---- App Config ------------------------------------------
CONFIDENCE_THRESHOLD=0.65
APP_ENV=production
